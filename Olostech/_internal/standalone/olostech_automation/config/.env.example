# Olostech API Credentials
# Copie este arquivo para .env e preencha com suas credenciais

OLOSTECH_USERNAME=seu_usuario_aqui
OLOSTECH_PASSWORD=sua_senha_aqui

# Base URL (geralmente não precisa mudar)
BASE_URL=https://w6.olostech.com.br

# Unidade padrão (Dispensário - Mandados Judiciais)
DEFAULT_UNIT_ID=2867#|#18208#|103,5,13,102,1,137,4
DEFAULT_UNIT_NAME=Dispensário - Mandados Judiciais

# Ambiente padrão (Dispensário da Farmácia Básica)
DEFAULT_ENVIRONMENT_ID=103|#MFB|#Dispensário da Farmácia Básica Release 8
DEFAULT_ENVIRONMENT_NAME=Dispensário da Farmácia Básica Release 8
